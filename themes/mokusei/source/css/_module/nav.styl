.nav
    background-color $navBgColor
    font-size 14px
    position fixed
    top 0px
    width 1360px
    padding 10px 0px 10px 40px
    z-index 100
    .nav-list
        float left
        text-align center
        > li
            margin 0px 5px
            display inline-block
            dl
                background-color $navBgColor
                display none
                position absolute
                z-index 1
                a
                    border-radius 0
                    font-size 12px
                    border-bottom 1px solid $borderColor

            &:hover
                > dl
                    display block
            a
                display block
                padding 8px 15px
                color $navTextColor
                @extend .transition
                border-radius 3px
                // border-right 1px solid #2d2d2d
                &.active
                    color #fff
                    font-weight bold
                    background-color $themeColor
                &:hover
                    color #fff
                    font-weight bold
                    background-color $themeColor
    .nav-tool
        float right
        margin-top 5px
        li
            display inline-block
            a
                color $navTextColor
                font-size 18px
                padding 8px 10px
                border-radius 3px
                &:hover
                    color #fff
                    background-color $themeColor
.search-panel
    display none
    border-radius 0px 0px 10px 10px
    width 420px
    height 270px
    background #fff
    top 50px
    right 0px
    position absolute
    z-index 100
    overflow-y auto
    border-width 2px
    border-style none solid solid solid
    border-color #FF4500 #FF4500 #FF4500






