@import "_base/variables.styl"
@import "_base/extend.styl"



body{
    background:url(/imgs/wallhaven.png);
    background-size:cover;
    background-repeat:no-repeat;
    background-attachment:fixed;
    background-position:center;
}

/*搜索框*/
.nav-search {
	position: relative;
}

.nav-search input {
	padding: 5px 10px;
	height: 25px;
    width: 250px;
    border-radius: 10px;
    border: none;
    outline: none;
    background: #F9F0DA;
    transition: .3s linear;
    float: right;
}
.nav-search input:focus {
    width: 400px;
    border-width: 2px;
    border-style: solid solid none solid;
    border-color: #FF4500 #FF4500 #FF4500;
    border-radius: 10px 10px 0px 0px;


    
}
.nav-search button {
	height: 35px;
	border: none;
    outline: none;
    width: 42px;
    cursor: pointer;
    position: absolute;
    background: none;
    right: 0;
}
.nav-search button:before{
  content: "\f002";
  font-family: FontAwesome;
  color: #324b4e;
}

@import "org/reset.css"

@import "org/highlight.css"

